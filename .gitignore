# Python
__pycache__/
*.py[cod]

# Node / frontend build deps
node_modules/
frontend/dist/

# Home Assistant runtime state (the dev instance) — keep config sources only
config/.storage/
config/.cloud/
config/.cache/
config/deps/
config/tts/
config/*.log
config/*.log.*
config/*.db
config/*.db-*
config/.HA_VERSION
config/.uuid
config/.ha_run.lock
config/home-assistant.log*
# Scenes are seeded/edited at runtime by the integration + the user
config/scenes.yaml

# HACS installed into the dev instance (not part of this project)
custom_components/hacs/
# HACS-generated gzip copies of served files (runtime artifact)
custom_components/homex/panel/*.gz

# HA default blueprints (shipped by HA at first run, not part of Homex)
config/blueprints/

# OS / editor
.DS_Store
